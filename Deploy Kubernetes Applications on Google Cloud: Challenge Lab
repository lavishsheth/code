# Default values
REPO_NAME="valkyrie-docker-repo"
IMAGE_NAME="valkyrie-dev"
IMAGE_TAG="v1"
REGION="us-west1"
ZONE="us-west1-b"

# Project ID
PROJECT_ID=$(gcloud config get-value project)

# Download application
if [ ! -d "valkyrie-app" ]; then
  gsutil cp gs://spls/gsp318/valkyrie-app.tgz .
  tar -xzf valkyrie-app.tgz
fi

cd valkyrie-app

# Create Dockerfile
cat > Dockerfile <<EOF
FROM golang:1.10
WORKDIR /go/src/app
COPY source .
RUN go install -v
ENTRYPOINT ["app","-single=true","-port=8080"]
EOF

# Image path
IMAGE_URI="${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO_NAME}/${IMAGE_NAME}:${IMAGE_TAG}"

# Create Artifact Registry (if not exists)
gcloud artifacts repositories describe "$REPO_NAME" --location="$REGION" >/dev/null 2>&1 || \
gcloud artifacts repositories create "$REPO_NAME" --repository-format=docker --location="$REGION"

# Configure auth
gcloud auth configure-docker "${REGION}-docker.pkg.dev" --quiet

# Build and push image
gcloud builds submit --tag "$IMAGE_URI" .

# Update deployment file
sed -i "s#IMAGE_HERE#${IMAGE_URI}#g" k8s/deployment.yaml

# Create cluster if not exists
CLUSTER="valkyrie-dev"
gcloud container clusters list --format="value(name)" | grep -q "$CLUSTER" || \
gcloud container clusters create "$CLUSTER" --zone "$ZONE" --num-nodes=1

# Connect to cluster
gcloud container clusters get-credentials "$CLUSTER" --zone "$ZONE"

# Deploy to Kubernetes
kubectl apply -f k8s/deployment.yaml
kubectl apply -f k8s/service.yaml

# Get service
kubectl get svc
